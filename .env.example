# Meta Ads API
META_ACCESS_TOKEN=your_meta_access_token_here
META_AD_ACCOUNT_ID=act_your_account_id
META_API_VERSION=v23.0

# LLM Config
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-3-7-sonnet-latest
LLM_MAX_TOKENS=1600
LLM_TEMPERATURE=0.2

# Database
DB_PATH=data/db/perf_marketing.sqlite3
VECTOR_DB_PATH=data/vector/chroma
REPORT_OUTPUT_DIR=output/reports
LOG_DIR=logs

# Email Config
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=your_email
EMAIL_SMTP_PASSWORD=your_app_password
EMAIL_FROM=your_email
EMAIL_TO=receiver_email

# WhatsApp (Twilio)
WHATSAPP_PROVIDER=twilio
WHATSAPP_ACCOUNT_SID=your_sid
WHATSAPP_AUTH_TOKEN=your_token
WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_TO=whatsapp:+91xxxxxxxxxx

# Scheduler
TIMEZONE=Asia/Kolkata
WEEKLY_CRON=0 8 * * MON